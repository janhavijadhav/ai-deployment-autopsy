# ─── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ─── Vector Store ───────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                         # leave blank for local
QDRANT_COLLECTION=procurement_contracts

# ─── Redis Cache ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600                    # seconds
SEMANTIC_CACHE_THRESHOLD=0.92           # cosine similarity

# ─── Database ───────────────────────────────────────────────────────────────────
DUCKDB_PATH=data/procurement.duckdb
SQLITE_PATH=data/sap_mirror.db

# ─── Auth / OAuth2 ──────────────────────────────────────────────────────────────
SUPPLIER_API_BASE_URL=http://localhost:8001
OAUTH2_TOKEN_URL=http://localhost:8001/oauth/token
OAUTH2_CLIENT_ID=procurement-agent
OAUTH2_CLIENT_SECRET=change_me_in_prod
OAUTH2_SCOPE=supplier.read contract.read approval.write

# ─── Observability ──────────────────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=http://localhost:3000     # self-hosted
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ─── Schema Monitor ─────────────────────────────────────────────────────────────
SCHEMA_MONITOR_ENABLED=true
SCHEMA_SNAPSHOT_PATH=data/schema_snapshots/
SCHEMA_ALERT_WEBHOOK=                   # Slack/PagerDuty webhook URL

# ─── Evals ──────────────────────────────────────────────────────────────────────
EVAL_FAITHFULNESS_THRESHOLD=0.85
EVAL_RELEVANCY_THRESHOLD=0.80
ADVERSARIAL_EVAL_COUNT=50
